#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: worktree-cleanup <worktree-path>" >&2
  echo "Example: worktree-cleanup ../photo-book-creator-wt/dev/123-intake-flow" >&2
  exit 1
fi

worktree_path="$1"

git worktree remove "$worktree_path"
git worktree prune

echo "Removed worktree: ${worktree_path}"
